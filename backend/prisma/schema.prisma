generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemParams {
  id        Int      @id @default(autoincrement())
  N         String
  H         String
  skA       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_params")
}

model VoterData {
  id         Int      @id @default(autoincrement())
  voterId    String
  ci         String?
  auxi       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  electionId String
  email      String   @unique
  password   String?
  role       String   @default("voter")

  @@unique([voterId, electionId])
  @@map("voter_data")
}

model AggregatedResult {
  id           Int      @id @default(autoincrement())
  aux          String?
  result       String
  decodedVotes String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  electionId   String   @unique

  @@map("aggregated_results")
}
