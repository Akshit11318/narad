{
  "name": "voting-system",
  "version": "2.0.0",
  "description": "Containerized Solana voting system with WASM-based cryptography",
  "license": "ISC",
  "private": true,
  "scripts": {
    "lint": "prettier --check \"backend/src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\" \"portal/src/**/*.{ts,tsx}\"",
    "lint:fix": "prettier --write \"backend/src/**/*.ts\" \"frontend/src/**/*.{ts,tsx}\" \"portal/src/**/*.{ts,tsx}\"",
    "test": "cd backend && npm test",
    "build": "npm run build:backend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:portal": "cd portal && npm run build",
    "build:wasm": "make build-wasm",
    "dev": "make dev",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:studio": "cd backend && npx prisma studio",
    "solana:build": "cargo build-sbf --release",
    "solana:test": "anchor test"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^9.1.1",
    "chai": "^4.5.0",
    "mocha": "^9.2.2",
    "prettier": "^3.5.3",
    "ts-mocha": "^11.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "solana",
    "blockchain",
    "voting",
    "wasm",
    "emscripten",
    "docker",
    "microservices"
  ]
}
