{
  "name": "voting-sys",
  "version": "1.0.0",
  "description": "Solana voting system monorepo",
  "license": "ISC",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "backend:build": "yarn workspace voting-sys-backend build",
    "backend:start": "yarn workspace voting-sys-backend start",
    "backend:dev": "yarn workspace voting-sys-backend dev",
    "test": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.87.6"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "typescript": "^5.3.3",
    "prettier": "^2.6.2"
  }
}
