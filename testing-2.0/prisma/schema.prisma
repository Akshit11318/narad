// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Table to store system parameters
model SystemParams {
  id        Int      @id @default(autoincrement())
  N         String   // Modulus N in hex
  H         String   // Hash H in hex
  skA       String?  // Aggregator's secret key in hex
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_params")
}

// Table to store voter data (ski, ci, auxi)
model VoterData {
  id         Int      @id @default(autoincrement())
  voterId    String   @unique // Unique identifier for the voter
  ci         String   // Ciphertext in hex
  auxi       String   // Auxiliary value in hex
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("voter_data")
}

// Table to store aggregated results
model AggregatedResult {
  id           Int      @id @default(autoincrement())
  aux          String?   // Final auxiliary value in hex
  result       String   // Aggregated result in hex
  decodedVotes String   // JSON string of decoded vote counts
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("aggregated_results")
}

// Table to store ZK proofs for votes
model ZKProof {
  id                  Int      @id @default(autoincrement())
  verificationCode    String   @unique @db.VarChar(16) // 16-digit alphanumeric verification code
  voterId             String   // References the voter who generated the proof
  electionId          String   // Identifies which election this proof belongs to
  
  // Complete ZK Proof data (JSON)
  zkProofData         String   @db.Text // Complete ZK proof as JSON
  
  // Public verification package (JSON)
  publicVerificationPackage String @db.Text // Public verification data as JSON
  
  // Legacy fields for backward compatibility
  commitments         String?  @db.Text // JSON string of commitment values
  challenges          String?  @db.Text // JSON string of challenge values  
  responses           String?  @db.Text // JSON string of response values
  publicParameters    String?  @db.Text // JSON string of public parameters used
  
  // Metadata
  timestamp           DateTime @default(now())
  verified            Boolean  @default(false)
  verificationAttempts Int     @default(0)
  lastVerificationAt  DateTime?
  
  // Proof generation metadata
  proofVersion        String   @default("1.0")
  wasmGenerated       Boolean  @default(true)
  securityLevel       Int      @default(2048)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("zk_proofs")
  @@index([verificationCode])
  @@index([voterId])
  @@index([electionId])
  @@index([timestamp])
}

// Table to store public verification attempts
model VerificationAttempt {
  id                  Int      @id @default(autoincrement())
  verificationCode    String   @db.VarChar(16) // 16-digit verification code
  ipAddress           String?  // IP address of verifier (optional)
  userAgent           String?  // User agent of verifier (optional)
  success             Boolean  // Whether verification succeeded
  verificationDetails String?  @db.Text // JSON with verification step details
  verificationTime    Int?     // Time taken to verify in milliseconds
  timestamp           DateTime @default(now())
  
  @@map("verification_attempts")
  @@index([verificationCode])
  @@index([timestamp])
  @@index([success])
}

// Table to store election parameters for ZK proofs
model ElectionParams {
  id          Int      @id @default(autoincrement())
  electionId  String   @unique
  
  // Cryptographic parameters
  prime       String   // Large prime p for ZK proofs
  generator   String   // Generator g for ZK proofs
  modulus     String   // Modulus for operations
  
  // Election metadata
  name        String   // Human-readable election name
  description String?  // Optional description
  startTime   DateTime // Election start time
  endTime     DateTime // Election end time
  active      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("election_params")
  @@index([electionId])
}
