{
  "name": "voting-system-testing",
  "version": "1.0.0",
  "description": "Testing environment for secure aggregation protocol in voting system",
  "main": "src/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "build:wasm": "cd ../../frontend/src/wasm && make && Copy-Item -Path 'build/*' -Destination '../../testing-2.0/src/scripts/' -Recurse -Force",
    "test": "npm run build:wasm && ts-mocha -p tsconfig.json -t 1000000 tests/**/*.ts",
    "test:blockchain": "node test-blockchain.js",
    "example:blockchain": "node examples/blockchain-example.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@prisma/client": "^5.7.0",
    "@solana/web3.js": "^1.87.6",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.7.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
