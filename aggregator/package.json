{
  "name": "voting-sys-aggregator",
  "version": "1.0.0",
  "description": "Node.js interface for the voting system aggregator",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:addon && tsc",
    "build:addon": "node-gyp rebuild",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "install": "node-gyp rebuild"
  },
  "engines": {
    "node": ">= 14.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bindings": "^1.5.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/bindings": "^1.5.5",
    "node-addon-api": "^8.3.1",
    "node-gyp": "^10.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  },
  "gypfile": true
}
